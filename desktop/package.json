{
  "name": "linker-pro-desktop",
  "version": "1.0.0",
  "description": "Linker Pro - Multi-Platform E-Commerce Dashboard",
  "main": "main.js",
  "author": "Linker Pro",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.linkerpro.app",
    "productName": "Linker Pro",
    "directories": {
      "output": "../dist-desktop"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html"
    ],
    "extraResources": [
      {
        "from": "../frontend/.next/standalone",
        "to": "app",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/.next/static",
        "to": "app/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/public",
        "to": "app/public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Linker Pro"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
