# Environment
NODE_ENV=development

# Server
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linker_pro?schema=public

# Optional Appwrite mirror (keeps PostgreSQL as primary)
APPWRITE_MIRROR_ENABLED=false
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_COLLECTION_PREFIX=lp_

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
# Azure Redis: set REDIS_PORT=6380 and REDIS_TLS=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for platform credentials)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Platform OAuth - Shopify
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders

# Platform OAuth - Salla
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_SCOPES=offline_access

# Platform OAuth - Amazon SP-API
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_IAM_ARN=

# Platform OAuth - Zid
ZID_CLIENT_ID=
ZID_CLIENT_SECRET=

# Platform OAuth - TikTok Shop
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# Platform OAuth - eBay
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Platform OAuth - Etsy
ETSY_API_KEY=
ETSY_SHARED_SECRET=

# Platform OAuth - Walmart
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# Platform OAuth - MercadoLibre
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=

# Platform OAuth - AliExpress
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# WooCommerce & Magento use per-store keys (stored in platform_connections)

# Webhook base URL
WEBHOOK_BASE_URL=https://your-domain.com/api/v1/webhooks

# Frontend URL
FRONTEND_URL=http://localhost:3001
